    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.159",
    "@types/jest": "^30.0.0",
    "esbuild": "0.27.2",
    "typescript": "^5.9.3"
  }
}
