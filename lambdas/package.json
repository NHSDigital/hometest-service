{
  "name": "@hometest-service/lambdas",
  "version": "1.0.0",
  "description": "Lambdas for the Home Test Service",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathIgnorePatterns=\\.integration\\.test\\.ts$ --coverage",
    "test:integration": "jest --testPathPatterns=\\.integration\\.test\\.ts$ --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "npx tsx scripts/build.ts",
    "package": "npx tsx scripts/package.ts",
    "local:deploy": "npm --prefix ../ run local:deploy",
    "local:terraform:apply": "npm --prefix ../ run local:terraform:apply",
    "clean": "rm -rf dist",
    "check-typescript": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "3.1021.0",
    "@aws-sdk/client-sqs": "3.1021.0",
    "@aws-sdk/rds-signer": "3.1021.0",
    "@middy/core": "7.2.1",
    "@middy/http-cors": "7.2.1",
    "@middy/http-error-handler": "7.2.1",
    "@middy/http-security-headers": "7.2.1",
    "axios": "1.14.0",
    "cookie": "1.1.1",
    "dayjs": "1.11.20",
    "esbuild": "0.27.4",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "4.0.1",
    "pg": "8.20.0",
    "titlecase": "1.1.3",
    "undici": "7.24.6",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.2",
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.2.0",
    "@testcontainers/postgresql": "11.13.0",
    "@types/archiver": "7.0.0",
    "@types/aws-lambda": "8.10.161",
    "@types/fhir": "0.0.41",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.0",
    "@types/pg": "8.20.0",
    "archiver": "7.0.1",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "jest-junit": "16.0.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  }
}
