{
  "name": "@hometest-service/lambdas",
  "version": "1.0.0",
  "description": "Lambdas for the Home Test Service",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathIgnorePatterns=\\.integration\\.test\\.ts$ --coverage",
    "test:integration": "jest --testPathPatterns=\\.integration\\.test\\.ts$ --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "npx tsx scripts/build.ts",
    "package": "npx tsx scripts/package.ts",
    "local:deploy": "npm --prefix ../ run local:deploy",
    "local:terraform:apply": "npm --prefix ../ run local:terraform:apply",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.996.0",
    "@aws-sdk/client-sqs": "^3.996.0",
    "@middy/core": "^7.1.1",
    "@middy/http-cors": "^7.1.1",
    "@middy/http-error-handler": "^7.1.1",
    "@middy/http-security-headers": "^7.1.1",
    "axios": "^1.13.5",
    "cookie": "^1.1.1",
    "dayjs": "^1.11.19",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "pg": "^8.18.0",
    "titlecase": "^1.1.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/archiver": "7.0.0",
    "@types/aws-lambda": "^8.10.160",
    "@types/fhir": "^0.0.41",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.13",
    "@types/pg": "^8.16.0",
    "archiver": "7.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
