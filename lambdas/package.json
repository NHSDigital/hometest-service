{
  "name": "@hometest-service/lambdas",
  "version": "1.0.0",
  "description": "Lambdas for the Home Test Service",
  "private": true,
  "workspaces": [
    "shared",
    "*-lambda"
  ],
  "scripts": {
    "build": "scripts/build.sh",
