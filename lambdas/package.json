{
  "name": "@hometest-service/lambdas",
  "version": "1.0.0",
  "description": "Lambdas for the Home Test Service",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "npx tsx scripts/build.ts",
    "package": "npx tsx scripts/package.ts",
    "local:deploy": "npm --prefix ../ run local:deploy",
    "local:terraform:apply": "npm --prefix ../ run local:terraform:apply",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.30.2",
    "@aws-lambda-powertools/tracer": "^2.30.2",
    "@aws-sdk/client-athena": "^3.978.0",
    "@aws-sdk/client-lambda": "^3.965.0",
    "@aws-sdk/client-secrets-manager": "^3.975.0",
    "@middy/core": "^6.4.5",
    "@middy/http-cors": "^6.4.5",
    "@middy/http-error-handler": "^6.4.5",
    "@middy/http-security-headers": "^6.4.5",
    "axios": "^1.13.4",
    "cookie": "^1.1.1",
    "dayjs": "^1.11.19",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "middy": "^0.24.0",
    "pg": "^8.16.3",
    "titlecase": "^1.1.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/archiver": "7.0.0",
    "@types/aws-lambda": "^8.10.159",
    "@types/fhir": "^0.0.41",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.16.0",
    "archiver": "7.0.1",
    "esbuild": "0.27.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "4.21.0",
    "typescript": "^5.9.3"
  }
