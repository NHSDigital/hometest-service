{
  "version": "0.0.1",
  "name": "nhs-home-test-service",
  "description": "NHS Home Test Service",
  "private": true,
  "scripts": {
    "start": "npm run local:up:localstack && npm run local:terraform:init && npm run local:deploy && npm run local:terraform:env && npm run local:up",
    "stop": "npm run local:terraform:destroy && npm run local:down",
    "test": "npm --prefix ui run test && npm --prefix lambdas run test",
    "local:up": "docker compose -f local-environment/docker-compose.yml up -d --force-recreate",
    "local:down": "docker compose -f local-environment/docker-compose.yml down",
    "local:up:ui": "docker compose -f local-environment/docker-compose.yml up -d ui",
    "local:down:ui": "docker compose -f local-environment/docker-compose.yml down ui",
    "local:up:db": "docker compose -f local-environment/docker-compose.yml up -d db",
    "local:down:db": "docker compose -f local-environment/docker-compose.yml down db",
    "local:up:localstack": "docker compose -f local-environment/docker-compose.yml up -d localstack",
    "local:down:localstack": "docker compose -f local-environment/docker-compose.yml down localstack",
    "local:restart": "npm run local:down && npm run local:up",
    "local:deploy": "npm run build:lambdas && npm run package:lambdas && npm run local:terraform:apply",
    "local:terraform:env": "bash scripts/terraform/post-apply-env-update.sh",
    "local:terraform:init": "terraform -chdir=local-environment/infra init",
    "local:terraform:plan": "terraform -chdir=local-environment/infra plan",
    "local:terraform:apply": "terraform -chdir=local-environment/infra apply -auto-approve",
    "local:terraform:destroy": "terraform -chdir=local-environment/infra destroy -auto-approve",
    "build:lambdas": "npm --prefix lambdas run build",
    "package:lambdas": "npm --prefix lambdas run package"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "source-map-support": "^0.5.21",
    "uuid": "^13.0.0"
  }
}
