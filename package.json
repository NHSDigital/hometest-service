{
  "name": "nhs-home-testing-service",
  "version": "0.0.1",
  "description": "NHS Home Testing Service",
  "private": true,
  "author": {
    "name": "Kainos",
    "organization": true
  },
  "license": "Apache-2.0",
  "scripts": {
    "lint": "eslint .",
    "lint-staged": "lint-staged",
    "format": "prettier --write .",
    "build": "tsc",
    "postbuild": "npm --prefix ./shared run clean",
    "watch": "tsc -w",
    "cdk": "cdk",
    "clean": "rm -rf infra/main/cdk.out infra/db/cdk.out infra/dev/cdk.out; tsc --build --clean",
    "reinstall": "rm -rf node_modules",
    "load-data": "./scripts/db/runDataLoad.sh",
    "generate-postman": "./scripts/postman/generatePostmanEnvFile.sh poc",
    "generate-queries": "node scripts/saved-queries/deploySavedQueries.js",
    "generate-env-files": "./scripts/dev-setup/generateEnvFiles.sh poc",
    "generate-athena-views": "./scripts/aws/athena-views-setup.sh",
    "pre-deploy": "./scripts/dev-setup/preDeploy.sh poc",
    "deploy": "./scripts/deploy.sh poc",
    "checkov": "./scripts/checkov.sh",
    "deploy-local": "./scripts/deploy-local.sh poc",
    "deploy-security": "./infra/security/scripts/deploy-security.sh",
    "run-local": "./scripts/run-local.sh poc",
    "post-deploy": "./scripts/dev-setup/postDeploy.sh",
    "destroy-env": "./scripts/destroy-env.sh",
    "test": "npm test --prefix ui && npm test --prefix lambdas",
    "test-ui": "npm test --prefix ui",
    "test-lambdas": "NODE_OPTIONS=\"--max-old-space-size=4096\" npm test --prefix lambdas",
    "prepare": "husky",
    "install-all": "npm i; npm i --prefix shared && npm i --prefix ui && npm i --prefix lambdas && npm i --prefix tests && npm i && npm i --prefix scripts/release-process/release-actions-runner && npm i --prefix data/mocks-generator",
    "ci-all": "npm ci; npm ci --prefix shared && npm ci --prefix ui && npm ci --prefix lambdas && npm ci --prefix tests && npm ci && npm ci --prefix scripts/release-process/release-actions-runner && npm ci --prefix data/mocks-generator",
    "deploy-apim": "./scripts/deploy-apim.sh",
    "local:infra": "docker-compose -f docker-compose.local.yml up -d",
    "local:infra:down": "docker-compose -f docker-compose.local.yml down",
    "local:infra:reset": "docker-compose -f docker-compose.local.yml down -v && docker-compose -f docker-compose.local.yml up -d",
    "local:install": "npm i --prefix scripts/local-dev",
    "local:db:init": "npm --prefix scripts/local-dev run init:tables",
    "local:db:seed": "npm --prefix scripts/local-dev run seed:data",
    "local:api": "npm --prefix scripts/local-dev run start:api",
    "local:ui": "cd ui && REACT_APP_AWS_ACCOUNT_NAME=local REACT_APP_ENV=local npm start",
    "local:setup": "npm run local:install && npm run local:infra && sleep 5 && npm run local:db:init && npm run local:db:seed",
    "localstack:start": "docker-compose -f docker-compose.localstack.yml up -d",
    "localstack:stop": "docker-compose -f docker-compose.localstack.yml down",
    "localstack:logs": "docker logs -f nht-localstack",
    "localstack:reset": "docker-compose -f docker-compose.localstack.yml down -v && docker-compose -f docker-compose.localstack.yml up -d",
    "localstack:wait": "bash scripts/localstack/wait-for-localstack.sh",
    "localstack:deploy": "bash scripts/localstack/deploy-local.sh",
    "localstack:env": "npx tsx scripts/localstack/generate-env.ts",
    "localstack:ui": "cd ui && REACT_APP_AWS_ACCOUNT_NAME=localstack REACT_APP_ENV=localstack npm start",
    "localstack:setup": "npm run localstack:start && npm run localstack:wait && echo 'LocalStack ready! Run npm run localstack:deploy for full CDK deployment'"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@aws-cdk/aws-glue-alpha": "^2.177.0-alpha.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.893.0",
    "@aws-sdk/client-resource-groups-tagging-api": "^3.893.0",
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "aws-cdk": "^2.1029.2",
    "csv-parser": "^3.2.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.36.0",
    "eslint-config-love": "^120.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-testing-library": "^7.8.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "3.3.3",
    "progress": "^2.0.3",
    "read-excel-file": "^5.8.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.229.1",
    "aws-sdk": "^2.1692.0",
    "cdk": "2.1019.1",
    "cdk-cross-account-route53": "^1.1.0",
    "constructs": "^10.4.2",
    "dotenv": "^16.6.1",
    "source-map-support": "^0.5.21"
  }
}
