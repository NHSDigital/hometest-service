{
  "version": "0.0.1",
  "name": "nhs-home-test-service",
  "description": "NHS Home Test Service",
  "private": true,
  "scripts": {
    "postinstall": "npm --prefix ui install && npm --prefix lambdas install",
    "start": "npm ci && npm run local:start",
    "stop": "npm run local:stop",
    "test": "npm --prefix ui run test && npm --prefix lambdas run test",
    "local:start": "npm run local:compose:up:force && npm run local:terraform:init && npm run local:terraform:apply && npm run local:terraform:env",
    "local:stop": "npm run local:terraform:destroy && npm run local:compose:down",
    "local:up:ui": "npm run local:compose -- up -d ui",
    "local:down:ui": "npm run local:compose -- down ui",
    "local:up:db": "npm run local:compose -- up -d postgres-db",
    "local:down:db": "npm run local:compose -- down postgres-db",
    "local:up:localstack": "npm run local:compose -- up -d localstack",
    "local:down:localstack": "npm run local:compose -- down localstack",
    "local:restart": "npm run local:down && npm run local:up",
    "local:deploy": "npm run build:lambdas && npm run package:lambdas && npm run local:terraform:apply",
    "local:terraform:env": "bash scripts/terraform/post-apply-env-update.sh",
    "local:terraform:init": "terraform -chdir=local-environment/infra init",
    "local:terraform:plan": "terraform -chdir=local-environment/infra plan",
    "local:terraform:apply": "terraform -chdir=local-environment/infra apply -auto-approve",
    "local:terraform:destroy": "terraform -chdir=local-environment/infra destroy -auto-approve",
    "build:lambdas": "npm --prefix lambdas run build",
    "package:lambdas": "npm --prefix lambdas run package",
    "local:compose": "docker compose -f local-environment/docker-compose.yml",
    "local:compose:up": "npm run local:compose -- up -d",
    "local:compose:up:force": "npm run local:compose -- up -d --force-recreate",
    "local:compose:down": "npm run local:compose -- down"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "source-map-support": "^0.5.21",
    "uuid": "^13.0.0"
  }
}
