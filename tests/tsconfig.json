{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "ignoreDeprecations": "5.0"
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["node_modules", "testResults"]
}
