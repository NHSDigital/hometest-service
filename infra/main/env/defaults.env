NOTIFY_JWT_EXPIRATION_TIME_SECONDS=180
NOTIFY_DB_COMMUNICATION_LOGS_TTL_DAYS=90

# mns
MNS_JWT_EXPIRATION_TIME_SECONDS=180

# nudges
## nudgeInitialAfterStart
NUDGE_INITIAL_AFTER_START_SCHEDULE='cron(0 18 ? * MON *)'
NUDGE_INITIAL_AFTER_START_TEMPLATE='NUDGE_INITIAL_AFTER_START'
NUDGE_INITIAL_AFTER_START_CRITERIA_NUMBER_OF_DAYS=5

# nhs login
NHS_LOGIN_CLIENT_ID="NHSDHC"
NHS_LOGIN_REDIRECT_URL=""

# Auth
AUTH_COOKIE_SAME_SITE="Strict"

# aws
AWS_NOTIFY_CALLBACK_API_DOMAIN_NAME=""
KMS_KEY_ID="af008d36-cc4a-4ed1-9841-0203a6029ae5" #gitleaks-ignore-line
SNS_KMS_KEY_ALIAS_NAME="alias/sns_key"
MANAGEMENT_ACCOUNT_ROUTE53_ROLE_NAME="nonprod-tgw-cross-account-update-rt-role"
MANAGEMENT_ACCOUNT_ID="637423623484"

# toggles
ENABLE_AUTO_EXPIRY=false
ENABLE_NHS_NUMBER_CHECK=false
ENABLE_REPORTING_DATA_COPY=false

# ENABLE_REPORTING_EXTERNAL_INTEGRATIONS only works if ENABLE_REPORTING_DATA_COPY is set to true
ENABLE_REPORTING_EXTERNAL_INTEGRATIONS=false
ENABLE_EVALUATOR_EXPORT=false
ALARMS_ENABLED=false
IMD_SCORES_ENABLED=true
ENABLE_GP_ONBOARDING_NOTIFICATIONS=false

# health check expiry
AUTO_EXPIRE_AFTER_DAYS=28
NO_LAB_RESULT_AUTO_WRITEBACK_AFTER_DAYS=28
NO_LAB_RESULT_AUTO_EXPIRE_AFTER_DAYS=90
NO_LAB_RESULT_FINAL_AUTO_EXPIRE_AFTER_DAYS=365

# logging
LOG_LEVEL="INFO"
LOG_RETENTION_IN_DAYS=14

# CSOC log forwarding
CSOC_LOG_FORWARDING_ENABLED=false
CSOC_EVENT_BUS_ARN="arn:aws:events:eu-west-2:693466633220:event-bus/shield-eventbus"

# tracing
AWS_XRAY_CONTEXT_MISSING=IGNORE_ERROR

GP_UPDATE_SCHEDULE_INTERVAL_IN_HOURS="24"

SQS_MAX_RECEIVE_COUNT="3"

# DLQ redrive
DLQ_REDRIVE_MAX_RETRIES_DEFAULT="14"

# reporting config
REPORTING_EC2_AMI_ID="ami-0bec21c97f5563d2f"
EVALUATOR_EXPORT_FILE_RETENTION_DAYS="7"
EVALUATOR_EXPORT_ROW_LIMIT='100000'
EVALUATOR_EXPORT_DELETE_SERVER_AFTER_DAYS="1"

LAMBDA_MEMORY_SIZE="1536"

GP_NOTIFICATION_SMTP_HOST="smtp.office365.com"
GP_NOTIFICATION_SMTP_PORT="587"

# gp email custom header
GP_NOTIFICATION_SMTP_ENABLE_SEND_CUSTOM_HEADER=true

# Default value for  CloudFormation stack termination protection in this environment
STACK_TERMINATION_PROTECTION_ENABLED=false
