GP_NOTIFICATION_SMTP_PASSWORD_SECRET_NAME="nhc/int/dnhc-smtp-password"

# Security
AMAZON_INSPECTOR_ENABLED=true

# tracing
TRACING_ENABLED=true

# mtls results API
MTLS_RESULTS_API_ENABLED=true

# nudges
## nudgeInitialAfterStart
NUDGE_INITIAL_AFTER_START_SCHEDULE='cron(0 18 ? * MON-THU *)'

# mns
