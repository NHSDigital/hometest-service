ENV_TYPE="prod"
DB_ENVIRONMENT="prod"
AWS_RESOURCES_REMOVAL_POLICY="RETAIN"
LOG_RETENTION_IN_DAYS=90

COOKIE_ACCESS_CONTROL_ALLOW_ORIGIN="https://nhs-health-check-online.service.nhs.uk"

# qrisk api
RISK_API_BASE_URL="https://api.endeavourpredict.org/epredict"
RISK_API_KEY_SECRET_NAME="nhc/prod/qcalc-api-key"

# os places
OS_PLACES_API_URL="https://api.os.uk/search/places/v1"
OS_PLACES_API_KEY_NAME="nhc/prod/os-places-api-key"

# nhs login
NHS_LOGIN_REDIRECT_URL="https://nhs-health-check-online.service.nhs.uk/login-callback"
NHS_LOGIN_BASE_ENDPOINT_URL="https://auth.login.nhs.uk"
NHS_LOGIN_PRIVATE_KEY_SECRET_NAME="nhc/prod/nhs-login-private-key"

# vpc
VPC_NAME="prod-prod-ipam-vpc-digitalHealthchecksProd"
VPC_ID="vpc-0de149a0ccaf7ad36"
VPC_SUBNET_IDS='["subnet-0387e3f9a59865a6e", "subnet-006bd905115a4988f", "subnet-0fa6b7f2a41e5f957"]'
VPC_SECURITY_GROUPS='["sg-0037f6e5f6efcb2c4"]'

# emis
EMIS_API_URL="https://emisconnect.spine.emis.thirdparty.nhs.uk/ITK"
EMIS_PRIVATE_KEY_SECRET_NAME="nhc/prod/emis-private-key"
EMIS_PUBLIC_CERT_SECRET_NAME="nhc/prod/emis-public-cert"
EMIS_PAYLOAD_ITK_GUID="ec354de4-66f9-459b-bf06-e61aa2546670"
EMIS_PAYLOAD_AUDIT_IDENTITY_ID="NHS Health Check online"

# nhs api platform
NHS_API_PLATFORM_BASE_URL="https://api.service.nhs.uk"
NHS_API_PLATFORM_KEY_ID="prod-1"
NHS_API_PLATFORM_API_KEY_SECRET_NAME="nhc/prod/nhs-api-platform-api-key"
NHS_API_PLATFORM_PRIVATE_KEY_SECRET_NAME="nhc/prod/nhs-api-platform-private-key/prod-1"
NHS_API_PLATFORM_APPLICATION_ID_SECRET_NAME="nhc/prod/nhs-api-platform-application-id"

# notify
NOTIFY_CALLBACK_API_KEY_SECRET_NAME="nhc/prod/notify-callback-api-key"
NOTIFY_CALLBACK_API_KEY_ID="prod-1"

# lab configuration - thriva
THRIVA_AUTH_API_URL="https://auth.thriva.io"
THRIVA_API_URL="https://api.thriva.io"
THRIVA_AUDIENCE_URL="https://api.euw2.thriva.io"
THRIVA_SECRET_KEY_SECRET_NAME="nhc/prod/thriva-secret"
THRIVA_CLIENT_ID_SECRET_NAME="nhc/prod/thriva-client-id"

# auth
AUTH_COOKIE_SIGNING_PRIVATE_KEYS_SECRET_NAME="nhc/prod/auth-cookie-signing-private-keys"
AUTH_COOKIE_SIGNING_PUBLIC_KEYS_SECRET_NAME="nhc/prod/auth-cookie-signing-public-keys"
AUTH_COOKIE_SIGNING_KID="prod-1"
AUTH_SESSION_MAX_DURATION_MINUTES=60
AUTH_ACCESS_TOKEN_EXPIRY_DURATION_MINUTES=3
AUTH_REFRESH_TOKEN_EXPIRY_DURATION_MINUTES=10

# aws
AWS_HOSTED_ZONE_ID="Z0487402XLIC7BSG8OOF"
AWS_CLOUDFRONT_HOSTED_ZONE_ID="Z2FDTNDATAQYW2" # see https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/quickref-route53.html#w41aac11c33c84c11
AWS_CLOUDFRONT_DOMAIN_NAME="nhs-health-check-online.service.nhs.uk"
AWS_BACKEND_API_DOMAIN_NAME="api.nhs-health-check-online.service.nhs.uk"
AWS_CALLBACK_API_DOMAIN_NAME="callback-api.nhs-health-check-online.service.nhs.uk"
AWS_RESULTS_API_DOMAIN_NAME="results-api.nhs-health-check-online.service.nhs.uk"
AWS_MTLS_RESULTS_API_DOMAIN_NAME="mtls-results-api.nhs-health-check-online.service.nhs.uk"

AWS_CLOUDFRONT_CERTIFICATE_ARN="arn:aws:acm:us-east-1:992382726377:certificate/70e32ae0-6be5-46fd-a9e8-eefb560c91ec"
AWS_BACKEND_API_GATEWAY_CERTIFICATE_ARN="arn:aws:acm:eu-west-2:992382726377:certificate/289597d6-2bee-4696-81eb-ff0bb0585291"
AWS_CALLBACK_API_CERTIFICATE_ARN="arn:aws:acm:eu-west-2:992382726377:certificate/876863d3-5aa0-4dee-be7b-34b690b35631"
AWS_RESULTS_API_GATEWAY_CERTIFICATE_ARN="arn:aws:acm:eu-west-2:992382726377:certificate/9f24193d-dc72-4264-8766-890f60090a98"
AWS_AUTH_DOMAIN_CERTIFICATE_ARN="arn:aws:acm:us-east-1:992382726377:certificate/71389b4d-597e-42bb-b947-b03a09ffe3ed"
AWS_CREATE_ROUTE53_RECORDS_IN_MANAGEMENT_ACCOUNT=true
MANAGEMENT_ACCOUNT_ROUTE53_ROLE_NAME="prod-tgw-cross-account-update-rt-role"
KMS_KEY_ID="46ceeda9-3b84-4f60-95df-422246da6bcc"  #gitleaks-ignore-line
AWS_MTLS_RESULTS_API_GATEWAY_CERTIFICATE_ARN="arn:aws:acm:eu-west-2:992382726377:certificate/41481060-b47d-4f54-b42c-2b3add49a842"

# logging
ACCESS_LOGGING_BUCKET_NAME="992382726377-prod-s3-access-bucket-logs"

# CSOC log forwarding
CSOC_LOG_FORWARDING_ENABLED=true

# RUM
RUM_CLOUDWATCH_LOGS_ENABLED=true

GP_UPDATE_SCHEDULE_INTERVAL_IN_HOURS="1"

# toggles
ENABLE_AUTO_EXPIRY=true
ENABLE_REPORTING_DATA_COPY=true
# ENABLE_REPORTING_EXTERNAL_INTEGRATIONS only works if ENABLE_REPORTING_DATA_COPY is set to true
ENABLE_REPORTING_EXTERNAL_INTEGRATIONS=true
ALARMS_ENABLED=true
ENABLE_GP_ONBOARDING_NOTIFICATIONS=true
ENABLE_NUDGES=true
ENABLE_EVALUATOR_EXPORT=true

# db table name overrides
TOWNSEND_TABLE_NAME="prod-nhc-townsend-db"

# DLQ redrive
DLQ_REDRIVE_AUTO_REDRIVE_ENABLED=true
DLQ_REDRIVE_MAX_RETRIES_LAB_ORDER_QUEUE=3

# BI reporting EC2 schedule - overnight (1:20 - 2:30 UTC time)
REPORTING_INSTANCE_START_SCHEDULE="20 1 ? * * *"
REPORTING_INSTANCE_STOP_SCHEDULE="30 2 ? * * *"
REPORTING_INSTANCE_KEY_PAIR_NAME="prod-bi-reporting-key"

# public key hosting
NHC_JWKS_SECRET_NAME="nhc/prod/jwks-public-keys"

# tracing
TRACING_ENABLED=true

# Security
AMAZON_INSPECTOR_ENABLED=true

# reporting config
EVALUATOR_EXPORT_DELETE_SERVER_AFTER_DAYS="7"

GP_NOTIFICATION_SMTP_USERNAME_SECRET_NAME="nhc/prod/dnhc-smtp-username"
GP_NOTIFICATION_SMTP_PASSWORD_SECRET_NAME="nhc/prod/dnhc-smtp-password"

# gp email custom header
GP_NOTIFICATION_SMTP_ENABLE_SEND_CUSTOM_HEADER=false

# mtls results API
MTLS_RESULTS_API_ENABLED=false

# nudges
## nudgeInitialAfterStart
NUDGE_INITIAL_AFTER_START_SCHEDULE='cron(0 18 ? * MON-THU *)'

# MNS
MNS_EVENTS_LAMBDA_DELIVERY_ROLE="arn:aws:iam::758334270304:role/nhs-mns-events-lambda-delivery"

# Enable CloudFormation stack termination protection in this environment
STACK_TERMINATION_PROTECTION_ENABLED=true

