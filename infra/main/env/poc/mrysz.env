OS_PLACES_API_URL="https://mrysz-mock-api.dhctest.org/address"
NHS_API_PLATFORM_BASE_URL="https://mrysz-mock-api.dhctest.org/nhs-api-platform"

COOKIE_ACCESS_CONTROL_ALLOW_ORIGIN="https://mrysz.dhctest.org"
AWS_BACKEND_API_DOMAIN_NAME="mrysz-api.dhctest.org"
AWS_CALLBACK_API_DOMAIN_NAME="mrysz-callback-api.dhctest.org"
AWS_RESULTS_API_DOMAIN_NAME="mrysz-results-api.dhctest.org"
AWS_MTLS_RESULTS_API_DOMAIN_NAME="mtls-mrysz-results-api.dhctest.org"


# nhs login
NHS_LOGIN_REDIRECT_URL="https://mrysz.dhctest.org/login-callback"
NHS_LOGIN_BASE_ENDPOINT_URL="https://mrysz-mock-api.dhctest.org/nhs-login"

# lab configuration - thriva
THRIVA_AUTH_API_URL="https://mrysz-mock-api.dhctest.org/lab/thriva"
THRIVA_API_URL="https://mrysz-mock-api.dhctest.org/lab/thriva"

LOG_LEVEL="DEBUG"

# emis
# EMIS_API_URL="http://3.11.93.54/ITK"
EMIS_API_URL="https://mrysz-mock-api.dhctest.org/emis-transaction-api"
# EMIS_PAYLOAD_ODS_OVERRIDE="A28579"

# toggles
ALARMS_ENABLED=false
ENABLE_AUTO_EXPIRY=true
ENABLE_REPORTING_DATA_COPY=false
# ENABLE_REPORTING_EXTERNAL_INTEGRATIONS only works if ENABLE_REPORTING_DATA_COPY is set to true
ENABLE_REPORTING_EXTERNAL_INTEGRATIONS=true
ENABLE_EVALUATOR_EXPORT=false
REPORTING_INSTANCE_KEY_PAIR_NAME="poc-bi-reporting-key"
EVALUATOR_EXPORT_FILE_RETENTION_DAYS="1"

ENABLE_GP_ONBOARDING_NOTIFICATIONS=false

ENABLE_NUDGES=true
