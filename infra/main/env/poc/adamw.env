DB_ENVIRONMENT="adamw"
RISK_API_BASE_URL="https://adamw-mock-api.dhctest.org/riskScores"
OS_PLACES_API_URL="https://adamw-mock-api.dhctest.org/address"
NHS_API_PLATFORM_BASE_URL="https://adamw-mock-api.dhctest.org/nhs-api-platform"

COOKIE_ACCESS_CONTROL_ALLOW_ORIGIN="https://adamw.dhctest.org"
AWS_BACKEND_API_DOMAIN_NAME="adamw-api.dhctest.org"
AWS_CALLBACK_API_DOMAIN_NAME="adamw-callback-api.dhctest.org"
AWS_RESULTS_API_DOMAIN_NAME="adamw-results-api.dhctest.org"
AWS_MTLS_RESULTS_API_DOMAIN_NAME="mtls-adamw-results-api.dhctest.org"

# nhs login
NHS_LOGIN_REDIRECT_URL="https://adamw.dhctest.org/login-callback"
NHS_LOGIN_BASE_ENDPOINT_URL="https://adamw-mock-api.dhctest.org/nhs-login"

# lab configuration - thriva
THRIVA_AUTH_API_URL="https://adamw-mock-api.dhctest.org/lab/thriva"
THRIVA_API_URL="https://adamw-mock-api.dhctest.org/lab/thriva"

LOG_LEVEL="DEBUG"
# toggles
ENABLE_AUTO_EXPIRY=true
# emis
EMIS_API_URL="https://adamw-mock-api.dhctest.org/emis-transaction-api"
# EMIS_PAYLOAD_ODS_OVERRIDE="A28579"

# BI reporting
ENABLE_REPORTING_DATA_COPY=true
ENABLE_REPORTING_EXTERNAL_INTEGRATIONS=true
ENABLE_EVALUATOR_EXPORT=true
REPORTING_INSTANCE_KEY_PAIR_NAME="adamw_bi_reporting_key"
IMD_SCORES_ENABLED=true