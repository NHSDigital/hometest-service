DB_ENVIRONMENT="sriv"
RISK_API_BASE_URL="https://sriv-mock-api.dhctest.org/riskScores"
EMIS_API_URL="https://sriv-mock-api.dhctest.org/emis-transaction-api"
OS_PLACES_API_URL="https://api.os.uk/search/places/v1"
# OS_PLACES_API_URL="https://sriv-mock-api.dhctest.org/address"
NHS_API_PLATFORM_BASE_URL="https://sriv-mock-api.dhctest.org/nhs-api-platform"

COOKIE_ACCESS_CONTROL_ALLOW_ORIGIN="https://sriv.dhctest.org"
AWS_BACKEND_API_DOMAIN_NAME="sriv-api.dhctest.org"
AWS_CALLBACK_API_DOMAIN_NAME="sriv-callback-api.dhctest.org"
AWS_RESULTS_API_DOMAIN_NAME="sriv-results-api.dhctest.org"
AWS_MTLS_RESULTS_API_DOMAIN_NAME="mtls-sriv-results-api.dhctest.org"


# nhs login
NHS_LOGIN_REDIRECT_URL="https://sriv.dhctest.org/login-callback"
NHS_LOGIN_BASE_ENDPOINT_URL="https://sriv-mock-api.dhctest.org/nhs-login"

# lab configuration - thriva
THRIVA_AUTH_API_URL="https://sriv-mock-api.dhctest.org/lab/thriva"
THRIVA_API_URL="https://sriv-mock-api.dhctest.org/lab/thriva"

# mtls results API
MTLS_RESULTS_API_ENABLED=false

GP_UPDATE_SCHEDULE_INTERVAL_IN_HOURS="1"

# DLQ redrive
DLQ_REDRIVE_AUTO_REDRIVE_ENABLED=true
DLQ_REDRIVE_MAX_RETRIES_LAB_ORDER_QUEUE=3

ALARMS_ENABLED=false
RUM_CLOUDWATCH_LOGS_ENABLED=true

# BI reporting EC2 schedule: everyday during working hours (07:30 - 17:30 UTC)
# REPORTING_INSTANCE_START_SCHEDULE="10 15 ? * * *"
# REPORTING_INSTANCE_STOP_SCHEDULE="05 15 ? * * *"

# BI reporting
ENABLE_REPORTING_DATA_COPY=true
ENABLE_REPORTING_EXTERNAL_INTEGRATIONS=true
ENABLE_EVALUATOR_EXPORT=true
REPORTING_INSTANCE_KEY_PAIR_NAME="sriv_bi_reporting_key"
IMD_SCORES_ENABLED=true
