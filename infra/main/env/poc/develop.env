DB_ENVIRONMENT="develop"
RISK_API_BASE_URL="https://develop-mock-api.dhctest.org/riskScores"
EMIS_API_URL="https://develop-mock-api.dhctest.org/emis-transaction-api"
OS_PLACES_API_URL="https://develop-mock-api.dhctest.org/address"
NHS_API_PLATFORM_BASE_URL="https://develop-mock-api.dhctest.org/nhs-api-platform"

COOKIE_ACCESS_CONTROL_ALLOW_ORIGIN="https://develop.dhctest.org"
AWS_BACKEND_API_DOMAIN_NAME="develop-api.dhctest.org"
AWS_CALLBACK_API_DOMAIN_NAME="develop-callback-api.dhctest.org"
AWS_RESULTS_API_DOMAIN_NAME="develop-results-api.dhctest.org"
AWS_MTLS_RESULTS_API_DOMAIN_NAME="mtls-develop-results-api.dhctest.org"

# nhs login
NHS_LOGIN_REDIRECT_URL="https://develop.dhctest.org/login-callback"
NHS_LOGIN_BASE_ENDPOINT_URL="https://develop-mock-api.dhctest.org/nhs-login"

# lab configuration - thriva
THRIVA_AUTH_API_URL="https://develop-mock-api.dhctest.org/lab/thriva"
THRIVA_API_URL="https://develop-mock-api.dhctest.org/lab/thriva"

# toggles
ENABLE_AUTO_EXPIRY=true
ENABLE_REPORTING_DATA_COPY=true
# ENABLE_REPORTING_EXTERNAL_INTEGRATIONS only works if ENABLE_REPORTING_DATA_COPY is set to true
ENABLE_REPORTING_EXTERNAL_INTEGRATIONS=true

REPORTING_INSTANCE_KEY_PAIR_NAME="develop-bi-reporting-key"

GP_UPDATE_SCHEDULE_INTERVAL_IN_HOURS="1"

# Security
AMAZON_INSPECTOR_ENABLED=true