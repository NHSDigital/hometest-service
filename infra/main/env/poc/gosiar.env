DB_ENVIRONMENT="gosiar"
RISK_API_BASE_URL="https://gosiar-mock-api.dhctest.org/riskScores"
EMIS_API_URL="https://gosiar-mock-api.dhctest.org/emis-transaction-api"
OS_PLACES_API_URL="https://api.os.uk/search/places/v1"
# OS_PLACES_API_URL="https://gosiar-mock-api.dhctest.org/address"
NHS_API_PLATFORM_BASE_URL="https://gosiar-mock-api.dhctest.org/nhs-api-platform"

COOKIE_ACCESS_CONTROL_ALLOW_ORIGIN="https://gosiar.dhctest.org"
AWS_BACKEND_API_DOMAIN_NAME="gosiar-api.dhctest.org"
AWS_CALLBACK_API_DOMAIN_NAME="gosiar-callback-api.dhctest.org"
AWS_RESULTS_API_DOMAIN_NAME="gosiar-results-api.dhctest.org"
AWS_MTLS_RESULTS_API_DOMAIN_NAME="mtls-gosiar-results-api.dhctest.org"


# nhs login
NHS_LOGIN_REDIRECT_URL="https://gosiar.dhctest.org/login-callback"
NHS_LOGIN_BASE_ENDPOINT_URL="https://gosiar-mock-api.dhctest.org/nhs-login"

# lab configuration - thriva
THRIVA_AUTH_API_URL="https://gosiar-mock-api.dhctest.org/lab/thriva"
THRIVA_API_URL="https://gosiar-mock-api.dhctest.org/lab/thriva"

GP_UPDATE_SCHEDULE_INTERVAL_IN_HOURS="1"

# DLQ redrive
DLQ_REDRIVE_AUTO_REDRIVE_ENABLED=true
DLQ_REDRIVE_MAX_RETRIES_LAB_ORDER_QUEUE=3

ALARMS_ENABLED=false
RUM_CLOUDWATCH_LOGS_ENABLED=true

ENABLE_REPORTING_DATA_COPY=true
# ENABLE_REPORTING_EXTERNAL_INTEGRATIONS only works if ENABLE_REPORTING_DATA_COPY is set to true
ENABLE_REPORTING_EXTERNAL_INTEGRATIONS=false
ENABLE_EVALUATOR_EXPORT=false

# BI reporting EC2 schedule: everyday during working hours (07:30 - 17:30 UTC)
# REPORTING_INSTANCE_START_SCHEDULE="10 15 ? * * *"
# REPORTING_INSTANCE_STOP_SCHEDULE="05 15 ? * * *"
REPORTING_INSTANCE_KEY_PAIR_NAME="develop-bi-reporting-key"
