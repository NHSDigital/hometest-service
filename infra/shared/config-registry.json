{
  "$schema": "../../scripts/validate-env/config-registry-schema.json",
  "app": "shared",
  "description": "CDK app containing shared resources",
  "variables": {
    "NHC_VERSION": {
      "description": "NHS Health Check service version",
      "type": "string",
      "example": "local"
    },
    "ENV_TYPE": {
      "description": "Environment type (prod or nonpord)",
      "type": "string",
      "example": "nonprod"
    },
    "ACCOUNT_NAME": {
      "description": "AWS account name",
      "type": "string",
      "example": "poc"
    },
    "EMAIL_VERIFICATION_DOMAIN": {
      "description": "The domain used for email verification",
      "scope": "non-prod",
      "type": "string",
      "example": "dhctest.org"
    },
    "ALARM_SECURITY_EMAIL": {
      "description": "Email for security notifications",
      "type": "string",
      "example": "DigitalHealthChecksSecurity@kainos.com"
    },
    "SNS_KMS_KEY_ALIAS_NAME": {
      "description": "KMS key alias name for SNS",
      "type": "string",
      "example": "alias/sns_key"
    },
    "KMS_KEY_ID": {
      "description": "KMS key ID",
      "type": "string",
      "example": "af008d36-cc4a-4ed1-9841-0203a6029ae5"
    },
    "MANAGEMENT_ACCOUNT_ID": {
      "description": "AWS management account ID",
      "type": "string",
      "example": "637423623484"
    },
    "AWS_HOSTED_ZONE_ID": {
      "description": "AWS Hosted Zone ID",
      "type": "string",
      "example": "Z0123456789ABCDEFGH"
    },
    "AWS_RESOURCES_REMOVAL_POLICY": {
      "description": "AWS resources removal policy",
      "type": "string",
      "example": "RETAIN"
    },
    "VPC_NAME": {
      "description": "VPC name",
      "type": "string",
      "example": "poc-nonprod-ipam-vpc-digitalHealthchecksPoc"
    },
    "VPC_ID": {
      "description": "VPC ID",
      "type": "string",
      "example": "vpc-0d0248a0afed0152e"
    },
    "VPC_SUBNET_IDS": {
      "description": "VPC subnet IDs",
      "type": "json",
      "example": "[\"subnet-0820572a40cfc7a46\", \"subnet-0f9ddbb1e9fc76fb6\", \"subnet-0c7e4341aee1d40bf\"]"
    },
    "VPC_SECURITY_GROUPS": {
      "description": "VPC security groups",
      "type": "json",
      "example": "[\"sg-0a1b2c3d4e5f6g7h8\"]"
    },
    "ACCESS_LOGGING_BUCKET_NAME": {
      "description": "S3 bucket name for access logging",
      "type": "string",
      "example": "my-access-logging-bucket"
    },
    "MANAGEMENT_ACCOUNT_ROUTE53_ROLE_NAME": {
      "description": "Managemenet account Route53 role name",
      "type": "string",
      "example": "prod-tgw-cross-account-update-rt-role"
    }
  }
}
