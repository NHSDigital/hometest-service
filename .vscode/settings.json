{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/*.d.ts": true,
    "**/dist": true
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "cSpell.words": ["emis", "Redrive", "Snomed"],
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/coverage": true,
    "**/build": true
  },
  "eslint.validate": [
    "typescript",
    "typescriptreact",
    "javascript",
    "javascriptreact",
    "json",
    "jsonc"
  ],
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [
    {
      "directory": ".",
      "changeProcessCWD": true
    }
  ],
  "eslint.options": {
    "overrideConfigFile": "./eslint.config.mjs"
  },
  "eslint.debug": false, // change to true to debug eslint issues (cmd_shift+u for the output console)
  "typescript.preferences.preferTypeOnlyAutoImports": true
}
