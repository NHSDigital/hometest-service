			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "{{authorization_header_value}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"orderId\": \"lab-order-id\",\n    \"orderExternalReference\": \"{orderId}\",\n    \"pendingReorder\": true,\n    \"resultData\": [\n        {\n            \"biomarkerCode\": \"GHBI\",\n            \"units\": \"mmol/L\",\n            \"value\": null,\n            \"successful\": false,\n            \"failureReasonCode\": \"not_calculated\",\n            \"failureReasonDescription\": \"The result was not calculated\"\n        },\n        {\n            \"biomarkerCode\": \"CHO\",\n            \"units\": \"mmol/L\",\n            \"value\": 6.3,\n            \"successful\": true\n        },\n        {\n            \"biomarkerCode\": \"HDL\",\n            \"units\": \"mmol/L\",\n            \"value\": 1.5,\n            \"successful\": true\n        },\n        {\n            \"biomarkerCode\": \"CHDD\",\n            \"units\": \"mmol/L\",\n            \"value\": 5,\n            \"successful\": true\n        }\n    ],\n    \"resultDate\": \"2023-12-11T15:44:37.685Z\"\n}",
					"options": {
