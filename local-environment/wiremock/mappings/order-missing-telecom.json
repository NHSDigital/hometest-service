{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/order",
    "headers": {
      "Content-Type": {
        "contains": "application/fhir+json"
      },
      "X-Correlation-ID": {
        "matches": ".*"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.contained[?(@.resourceType == 'Patient' && !@.telecom)]"
      }
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/fhir+json"
    },
    "jsonBody": {
      "resourceType": "OperationOutcome",
      "issue": [
        {
          "severity": "error",
          "code": "required",
          "details": {
            "text": "Validation Error"
          },
          "diagnostics": "Patient must have telecom array with at least 2 entries including phone and email",
          "expression": ["ServiceRequest.contained[0].telecom"]
        }
      ]
    }
  }
}
