          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Get patient data" enabled="true">
            <stringProp name="HTTPSampler.domain">${HEALTH_CHECK_API_DOMAIN}</stringProp>
