{
	"info": {
		"_postman_id": "573c5e75-fc4e-41f6-a2b1-ad1dcfa32fc6",
		"name": "NHS Login Auth (Sandpit)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "19518888"
	},
	"item": [
		{
			"name": "Retrieve Token",
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/x-www-form-urlencoded",
						"type": "text"
					}
				],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{
							"key": "grant_type",
							"value": "authorization_code",
							"type": "text"
						},
						{
							"key": "code",
							"value": "<code_from_auth_url>",
							"type": "text"
						},
						{
							"key": "redirect_uri",
							"value": "http://localhost:3000/callback",
							"type": "text"
						},
						{
							"key": "client_id",
							"value": "hometest",
							"type": "text"
						},
						{
							"key": "client_assertion_type",
							"value": "urn:ietf:params:oauth:client-assertion-type:jwt-bearer",
							"type": "text"
						},
						{
							"key": "client_assertion",
							"value": "<signed_jwt>",
							"type": "text"
						}
					]
				},
				"url": {
					"raw": "https://auth.sandpit.signin.nhs.uk/token",
					"protocol": "https",
					"host": [
						"auth",
						"sandpit",
						"signin",
						"nhs",
						"uk"
					],
					"path": [
						"token"
					]
				}
			},
			"response": []
		}
	]
}