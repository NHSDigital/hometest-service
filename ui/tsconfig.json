{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024", "dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/content/*": ["./content/*"],
      "@/content": ["./content/index.ts"],
      "@/hooks/*": ["./hooks/*"],
      "@/hooks": ["./hooks/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.mts",
    "build/types/**/*.ts",
    "build/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
