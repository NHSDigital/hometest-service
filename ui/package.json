{
  "name": "@nhs-home-testing/ui",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.893.0",
    "@nhs-home-testing/shared": "file:../shared",
    "@tanstack/react-query": "^5.90.1",
    "@types/node": "^20.19.17",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/react-router": "^5.1.20",
    "@types/styled-components": "^5.1.34",
    "aws-rum-web": "^1.25.0",
    "axios": "^1.12.2",
    "dayjs": "^1.11.19",
    "lodash": "^4.17.21",
    "nhsuk-react-components": "^5.0.0",
    "nhsuk-tools-chart-components-react": "^1.1.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-idle-timer": "^5.7.2",
    "react-router-dom": "^6.30.1",
    "react-scripts": "^5.0.1",
    "styled-components": "^6.1.19",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "undici": "^6.21.3",
    "web-vitals": "^3.5.2"
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "prestart": "npm --prefix ../shared run build && ./src/scripts/prepare-build.sh",
    "start": "sh -ac '. ./env/defaults.env; if [ -f ./env/${REACT_APP_AWS_ACCOUNT_NAME}/${REACT_APP_ENV}.env ]; then . ./env/${REACT_APP_AWS_ACCOUNT_NAME}/${REACT_APP_ENV}.env; fi; . ./env/local-overrides.env; react-scripts start'",
    "poststart": "npm --prefix ../shared run clean",
    "prebuild": "npm --prefix ../shared run clean && npm --prefix ../shared run build && ./src/scripts/prepare-build.sh",
    "build": "sh -ac '. ./env/defaults.env; if [ -f ./env/${REACT_APP_AWS_ACCOUNT_NAME}/${REACT_APP_ENV}.env ]; then . ./env/${REACT_APP_AWS_ACCOUNT_NAME}/${REACT_APP_ENV}.env; fi; DISABLE_ESLINT_PLUGIN=true react-scripts build && node ./src/scripts/prepare-static-pages.js'",
    "postbuild": "npm --prefix ../shared run clean",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "eject": "react-scripts eject"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.20",
    "@types/react-helmet": "^6.1.11",
    "dotenv": "^16.6.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-testing-library": "^7.8.1",
    "globals": "^16.4.0",
    "history": "^5.3.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "2.3.0",
    "sass": "^1.93.0",
    "ts-jest": "^29.4.4",
    "typescript-eslint": "^8.44.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "react-scripts": {
      "postcss": ">=8.4.31"
    },
    "svgo": {
      "nth-check": ">=2.0.1"
    },
    "cookie": "0.7.0",
    "minimatch@2.31.0": {
      "brace-expansion": ">=1.1.12"
    }
  }
}
