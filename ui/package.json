{
  "name": "hometest-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env STATIC_EXPORT=true next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "serve:static": "pnpm run build && pnpm exec http-server build -p 8085 -c-1 --proxy http://localhost:8085?",
    "check-typescript": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "5.97.0",
    "next": "16.2.4",
    "nhsuk-frontend": "10.4.2",
    "nhsuk-react-components": "6.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/fhir": "0.0.41",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "10.1.0",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-junit": "16.0.0",
    "http-server": "14.1.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}
