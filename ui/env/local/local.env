REACT_APP_NHS_LOGIN_BASE_URL="http://localhost:4000/mock/nhs-login"
REACT_APP_NHS_APP_URL="http://localhost:4000/mock/nhs-app"

# App versions
REACT_APP_NHT_VERSION="2.0.0-local"
REACT_APP_CURRENT_TERMS_VERSION="1.0"
REACT_APP_MANUFACTURE_DATE="01/01/2025"
REACT_APP_HOME_TESTING_DATA_MODEL_VERSION="3.0.0"

# RUM disabled for local
REACT_APP_APP_MONITOR_ID=""
